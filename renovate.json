{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "github-actions": {
    "managerFilePatterns": [
      "/^\\.github/workflows/.*\\.ya?ml$/",
      "/^\\.github/actions/.*\\.ya?ml$/",
      "/^examples/ci-example\\.ya?ml$/"
    ]
  },
  "ignorePaths": [
    "src/nginx/values.yaml"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update tool versions annotated with '# renovate:' inline comments in YAML files",
      "managerFilePatterns": [
        "/\\.ya?ml$/",
        "/^examples/\\.gitlab-ci\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>\\S+)(?:\\s+extractVersion=(?<extractVersion>\\S+))?(?:\\s+versioning=(?<versioning>\\S+))?\\s*\\n\\s+default: (?<currentValue>\\S+)",
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>\\S+)(?:\\s+extractVersion=(?<extractVersion>\\S+))?(?:\\s+versioning=(?<versioning>\\S+))?\\s*\\nappVersion: [\"']?(?<currentValue>[^\"'\\s]+)[\"']?",
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>\\S+)(?:\\s+extractVersion=(?<extractVersion>\\S+))?(?:\\s+versioning=(?<versioning>\\S+))?\\s*\\n\\s+[A-Z_]+: (?<currentValue>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "description": "Update SHA-pinned GitHub Actions references in README.md",
      "managerFilePatterns": [
        "/^README\\.md$/"
      ],
      "matchStrings": [
        "uses: (?<depName>[\\w.-]+/[\\w.-]+)[^@\\n]*@(?<currentDigest>[a-f0-9]{40})(?:\\s*#\\s*(?<currentValue>\\S+))?"
      ],
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update version-tagged GitHub Actions references in README.md",
      "managerFilePatterns": [
        "/^README\\.md$/"
      ],
      "matchStrings": [
        "uses: (?<depName>[\\w.-]+/[\\w.-]+)@(?<currentValue>v[\\d.]+)"
      ],
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "description": "Update version-tagged raw.githubusercontent.com udm-common task includes",
      "managerFilePatterns": [
        "/^README\\.md$/",
        "/^examples/.*\\.ya?ml$/"
      ],
      "matchStrings": [
        "https://raw\\.githubusercontent\\.com/(?<depName>defenseunicorns-udm/udm-common)/(?<currentValue>v[\\d.]+)/tasks/"
      ],
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["docker", "github-actions", "github-releases"],
      "minimumReleaseAge": "3 days",
      "internalChecksFilter": "strict"
    },
    {
      "matchDepNames": ["defenseunicorns-udm/udm-common"],
      "groupName": "udm-common self-references",
      "automerge": false,
      "minimumReleaseAge": "0 days"
    }
  ]
}
